rules_version = '2';

// Règles Firestore — Nounou Express (Phase 3)
//
// Schéma :
//   users/{uid}                          profil + rôle ('parent'|'nanny')
//   users/{uid}/conversations/{otherId}  index de conversations (miroir)
//   users/{uid}/notifications/{id}       notifications (écrites par backend)
//   users/{uid}/dashboard/{doc}          stats (calculées par backend)
//   nannies/{uid}                        profil public nounou (doc id = uid)
//   bookings/{id}                        réservations (parentId / nannyId)
//   missions/{id}                        annonces (parentId, selectedNannyId)
//   applications/{id}                    candidatures (nannyId, missionId)
//   chats/{threadId}/messages/{id}       threadId = uids triés joints par '_'
//   config/{doc}                         référentiels (quartiers...) lecture seule
//
// NOTE : le rôle vit dans users/{uid}.role (modifiable par le propriétaire).
// À durcir avec des custom claims dès qu'un backend d'admin existe (Phase 4).
// Déploiement : firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, create, update: if isOwner(uid);
      allow delete: if false;

      match /conversations/{otherId} {
        // Le propriétaire lit/écrit son index ; l'interlocuteur peut écrire
        // le miroir (mise à jour de lastMessage lors d'un envoi).
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) || isOwner(otherId);
      }

      match /notifications/{notificationId} {
        allow read, update: if isOwner(uid);
        allow create, delete: if false; // écrites par le backend uniquement
      }

      match /dashboard/{doc} {
        allow read: if isOwner(uid);
        allow write: if false; // calculées par le backend uniquement
      }
    }

    match /nannies/{nannyId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(nannyId);
      allow delete: if false;
    }

    match /bookings/{bookingId} {
      allow read, update: if isSignedIn() &&
          (resource.data.parentId == request.auth.uid ||
           resource.data.nannyId == request.auth.uid);
      allow create: if isSignedIn() &&
          request.resource.data.parentId == request.auth.uid;
      allow delete: if false;
    }

    match /missions/{missionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
          request.resource.data.parentId == request.auth.uid;
      allow update: if isSignedIn() &&
          (resource.data.parentId == request.auth.uid ||
           resource.data.selectedNannyId == request.auth.uid);
      allow delete: if isSignedIn() &&
          resource.data.parentId == request.auth.uid;
    }

    match /applications/{applicationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
          request.resource.data.nannyId == request.auth.uid;
      allow update: if isSignedIn() &&
          (resource.data.nannyId == request.auth.uid ||
           get(/databases/$(database)/documents/missions/$(resource.data.missionId))
               .data.parentId == request.auth.uid);
      allow delete: if false;
    }

    match /chats/{threadId}/messages/{messageId} {
      // threadId = "<uidA>_<uidB>" (uids triés) : seuls les participants.
      allow read, create: if isSignedIn() &&
          threadId.split('_').hasAny([request.auth.uid]);
      allow update, delete: if false;
    }

    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Tout le reste : refusé.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
