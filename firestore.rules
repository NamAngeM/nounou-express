rules_version = '2';

// Règles Firestore — Nounou Express (Phase 3)
//
// Schéma :
//   users/{uid}                          profil + rôle ('parent'|'nanny')
//   users/{uid}/conversations/{otherId}  index de conversations (miroir)
//   users/{uid}/notifications/{id}       notifications (écrites par backend)
//   users/{uid}/dashboard/{doc}          stats (calculées par backend)
//   nannies/{uid}                        profil public nounou (doc id = uid)
//   bookings/{id}                        réservations (parentId / nannyId)
//   missions/{id}                        annonces (parentId, selectedNannyId)
//   applications/{id}                    candidatures (nannyId, missionId)
//   reviews/{id}                         avis post-mission (fromUserId, toUserId)
//   sos_alerts/{id}                      alertes SOS (fromUserId, missionId)
//   chats/{threadId}/messages/{id}       threadId = uids triés joints par '_'
//   config/{doc}                         référentiels (quartiers...) lecture seule
//
// Le rôle est désormais injecté comme custom claim par la Cloud Function
// `setUserRole` (functions/src/index.ts). Le helper `hasRole()` ci-dessous
// lit `request.auth.token.role` — infalsifiable côté client.
// Déploiement : firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    match /users/{uid} {
      allow read, create, update: if isOwner(uid);
      allow delete: if false;

      match /conversations/{otherId} {
        // Le propriétaire lit/écrit son index ; l'interlocuteur peut écrire
        // le miroir (mise à jour de lastMessage lors d'un envoi).
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) || isOwner(otherId);
      }

      match /notifications/{notificationId} {
        // Le propriétaire gère son fil (lecture, marquage lu, suppression,
        // et création de ses propres traces — ex. alerte SOS). Les
        // notifications inter-utilisateurs passent par les Cloud Functions
        // (Admin SDK, hors règles).
        allow read, create, update, delete: if isOwner(uid);
      }

      match /dashboard/{doc} {
        allow read: if isOwner(uid);
        allow write: if false; // calculées par le backend uniquement
      }
    }

    match /nannies/{nannyId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(nannyId);
      allow delete: if false;
    }

    match /bookings/{bookingId} {
      allow read, update: if isSignedIn() &&
          (resource.data.parentId == request.auth.uid ||
           resource.data.nannyId == request.auth.uid);
      allow create: if isSignedIn() &&
          request.resource.data.parentId == request.auth.uid;
      allow delete: if false;
    }

    match /missions/{missionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
          request.resource.data.parentId == request.auth.uid;
      allow update: if isSignedIn() &&
          (resource.data.parentId == request.auth.uid ||
           resource.data.selectedNannyId == request.auth.uid);
      allow delete: if isSignedIn() &&
          resource.data.parentId == request.auth.uid;
    }

    match /applications/{applicationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
          request.resource.data.nannyId == request.auth.uid;
      allow update: if isSignedIn() &&
          (resource.data.nannyId == request.auth.uid ||
           get(/databases/$(database)/documents/missions/$(resource.data.missionId))
               .data.parentId == request.auth.uid);
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      // Avis publics (affichés sur les profils). L'auteur crée/corrige
      // son propre avis (id déterministe bookingId_fromUserId côté app).
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() &&
          request.resource.data.fromUserId == request.auth.uid;
      allow delete: if false;
    }

    match /sos_alerts/{alertId} {
      // Création par l'émetteur uniquement ; relais et champs
      // relayedTo/relayedAt écrits par la Cloud Function (Admin SDK).
      allow create: if isSignedIn() &&
          request.resource.data.fromUserId == request.auth.uid;
      allow read: if isSignedIn() &&
          resource.data.fromUserId == request.auth.uid;
      allow update, delete: if false;
    }

    match /chats/{threadId}/messages/{messageId} {
      // threadId = "<uidA>_<uidB>" (uids triés) : seuls les participants.
      allow read, create: if isSignedIn() &&
          threadId.split('_').hasAny([request.auth.uid]);
      allow update, delete: if false;
    }

    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Tout le reste : refusé.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
